generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @id @default(autoincrement())
  name     String
  email    String    @unique
  password String
  role     String
  bookings Booking[]
}

model Bus {
  id            Int      @id @default(autoincrement())
  busName       String
  fromCity      String
  toCity        String
  departureTime String?
  arrivalTime   String?
  price         Int
  totalSeats    Int      @default(40)
  stops         String[]
}

model Booking {
  id                Int     @id @default(autoincrement())
  userId            Int
  fromCity          String
  toCity            String
  fare              Int
  pnr               String? @unique
  paymentStatus     String  @default("PENDING")
  razorpayOrderId   String?
  razorpayPaymentId String?

  user User @relation(fields: [userId], references: [id])
}
